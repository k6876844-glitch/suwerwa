  <!-- ═══ MODALS ═══ -->

  <!-- Add News Modal -->
  <div class="modal-overlay" id="modalNews">
    <div class="modal">
      <div class="modal-header">
        <span><i class="fas fa-newspaper"></i> Publish News Article</span>
        <button class="modal-close" onclick="closeModal('modalNews')"><i class="fas fa-times"></i></button>
      </div>
      <form class="modal-form" id="newsForm">
        <div class="form-group">
          <label>Title *</label>
          <input type="text" id="nTitle" placeholder="e.g. Inter-School Athletics Win" required>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Category</label>
            <select id="nCategory">
              <option>General</option><option>Sports</option><option>Academic</option>
              <option>Culture</option><option>Infrastructure</option>
            </select>
          </div>
          <div class="form-group">
            <label>Author</label>
            <input type="text" id="nAuthor" placeholder="Sports Department">
          </div>
        </div>
        <div class="form-group">
          <label>Emoji Icon</label>
          <input type="text" id="nEmoji" placeholder="📰" maxlength="4">
        </div>
        <div class="form-group">
          <label>Content *</label>
          <textarea id="nContent" rows="4" placeholder="Write the full news article here…" required></textarea>
        </div>
        <button type="submit" class="btn btn-navy" style="width:100%;justify-content:center">
          <i class="fas fa-paper-plane"></i> Publish News
        </button>
      </form>
    </div>
  </div>

  <!-- Add Notice Modal -->
  <div class="modal-overlay" id="modalNotice">
    <div class="modal">
      <div class="modal-header">
        <span><i class="fas fa-bullhorn"></i> Post Notice</span>
        <button class="modal-close" onclick="closeModal('modalNotice')"><i class="fas fa-times"></i></button>
      </div>
      <form class="modal-form" id="noticeForm">
        <div class="form-group">
          <label>Title *</label>
          <input type="text" id="ntTitle" placeholder="e.g. Term 3 Fee Deadline" required>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Category</label>
            <select id="ntCategory">
              <option>General</option><option>Finance</option><option>Academic</option>
              <option>Sports</option><option>Library</option>
            </select>
          </div>
          <div class="form-group">
            <label>Posted By</label>
            <input type="text" id="ntPostedBy" placeholder="Administration">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Expires On</label>
            <input type="date" id="ntExpires">
          </div>
          <div class="form-group" style="justify-content:center">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin-top:22px">
              <input type="checkbox" id="ntUrgent" style="width:16px;height:16px"> Mark as Urgent
            </label>
          </div>
        </div>
        <div class="form-group">
          <label>Content *</label>
          <textarea id="ntContent" rows="4" placeholder="Write the notice content here…" required></textarea>
        </div>
        <button type="submit" class="btn btn-navy" style="width:100%;justify-content:center">
          <i class="fas fa-paper-plane"></i> Post Notice
        </button>
      </form>
    </div>
  </div>

  <!-- Add Event Modal -->
  <div class="modal-overlay" id="modalEvent">
    <div class="modal">
      <div class="modal-header">
        <span><i class="fas fa-calendar-plus"></i> Add Event</span>
        <button class="modal-close" onclick="closeModal('modalEvent')"><i class="fas fa-times"></i></button>
      </div>
      <form class="modal-form" id="eventForm">
        <div class="form-group">
          <label>Event Title *</label>
          <input type="text" id="evTitle" placeholder="e.g. Prize Giving Day" required>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Date *</label>
            <input type="date" id="evDate" required>
          </div>
          <div class="form-group">
            <label>Type</label>
            <select id="evType">
              <option>Event</option><option>School</option><option>Exam</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Venue</label>
          <input type="text" id="evVenue" placeholder="School Grounds">
        </div>
        <div class="form-group">
          <label>Description</label>
          <textarea id="evDesc" rows="3" placeholder="Brief description of the event…"></textarea>
        </div>
        <button type="submit" class="btn btn-navy" style="width:100%;justify-content:center">
          <i class="fas fa-paper-plane"></i> Add Event
        </button>
      </form>
    </div>
  </div>

  <!-- Add Photo Modal -->
  <div class="modal-overlay" id="modalGallery">
    <div class="modal">
      <div class="modal-header">
        <span><i class="fas fa-image"></i> Add Gallery Photo</span>
        <button class="modal-close" onclick="closeModal('modalGallery')"><i class="fas fa-times"></i></button>
      </div>
      <form class="modal-form" id="galleryForm">
        <div class="form-group">
          <label>Image URL *</label>
          <input type="url" id="gUrl" placeholder="https://example.com/photo.jpg" required>
        </div>
        <div class="form-group">
          <label>Category</label>
          <select id="gCategory">
            <option value="academics">Academics</option>
            <option value="sports">Sports &amp; Games</option>
            <option value="events">Events</option>
            <option value="campus" selected>Campus</option>
            <option value="scouts">Scouts &amp; Clubs</option>
          </select>
        </div>
        <div class="form-group">
          <label>Caption *</label>
          <input type="text" id="gCaption" placeholder="e.g. Prize Giving Day 2026" required>
        </div>
        <div class="form-group">
          <label>Link to Event (optional)</label>
          <select id="gEvent">
            <option value="">None</option>
          </select>
        </div>
        <button type="submit" class="btn btn-navy" style="width:100%;justify-content:center">
          <i class="fas fa-paper-plane"></i> Add Photo
        </button>
      </form>
    </div>
  </div>

