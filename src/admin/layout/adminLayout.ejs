<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex, nofollow">
  <title>Admin Dashboard — St Francis Girls Suwerwa</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Inter:wght@300;400;500;600;700&family=Fira+Code:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
  <link rel="stylesheet" href="/admin/static/dashboard.css">
  <style>
    .user-menu { display: flex; align-items: center; gap: 8px; }
    .logout-form { margin: 0; }
    .logout-btn {
      background: none; border: none; cursor: pointer;
      color: inherit; font-size: 0.95rem; opacity: 0.7; padding: 4px;
      display: flex; align-items: center;
    }
    .logout-btn:hover { opacity: 1; }
  </style>
</head>
<body>

<!-- ═══ SIDEBAR ═══ -->
<aside class="sidebar" id="sidebar">
  <div class="sidebar-header">
    <div class="sb-logo">
      <div class="sb-badge">SFG</div>
      <div class="sb-name">
        <span class="sb-school">St Francis Girls</span>
        <span class="sb-location">Suwerwa · Kitale</span>
      </div>
    </div>
    <button class="sidebar-close" id="sidebarClose"><i class="fas fa-times"></i></button>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-group">
      <span class="nav-group-label">Overview</span>
      <a href="#overview"  class="nav-item active" data-section="overview">
        <i class="fas fa-th-large"></i> Dashboard
      </a>
      <a href="#analytics" class="nav-item" data-section="analytics">
        <i class="fas fa-chart-bar"></i> Analytics
      </a>
    </div>

    <div class="nav-group">
      <span class="nav-group-label">School Website</span>
      <a href="/index.html"       target="_blank" class="nav-item ext"><i class="fas fa-home"></i> Home</a>
      <a href="/profile.html"        target="_blank" class="nav-item ext"><i class="fas fa-school"></i> Our Profile</a>
      <a href="/history.html"        target="_blank" class="nav-item ext"><i class="fas fa-landmark"></i> History</a>
      <a href="/vision.html"         target="_blank" class="nav-item ext"><i class="fas fa-eye"></i> Vision &amp; Mission</a>
      <a href="/administration.html" target="_blank" class="nav-item ext"><i class="fas fa-user-tie"></i> Administration</a>
      <a href="/staff.html"          target="_blank" class="nav-item ext"><i class="fas fa-users"></i> Staff</a>
      <a href="/news.html"           target="_blank" class="nav-item ext"><i class="fas fa-newspaper"></i> News &amp; Events</a>
      <a href="/noticeboard.html"    target="_blank" class="nav-item ext"><i class="fas fa-bullhorn"></i> Notice Board</a>
      <a href="/clubs.html"          target="_blank" class="nav-item ext"><i class="fas fa-star"></i> Clubs &amp; Societies</a>
      <a href="/gallery.html"        target="_blank" class="nav-item ext"><i class="fas fa-images"></i> Gallery</a>
      <a href="/kcse.html"           target="_blank" class="nav-item ext"><i class="fas fa-award"></i> KCSE Results</a>
      <a href="/facilities.html"     target="_blank" class="nav-item ext"><i class="fas fa-building"></i> Facilities</a>
    </div>

    <div class="nav-group">
      <span class="nav-group-label">Admissions</span>
      <a href="/adm-overview.html"  target="_blank" class="nav-item ext"><i class="fas fa-info-circle"></i> Overview</a>
      <a href="/criteria.html"      target="_blank" class="nav-item ext"><i class="fas fa-list-check"></i> Criteria</a>
      <a href="/fee.html"           target="_blank" class="nav-item ext"><i class="fas fa-money-bill-wave"></i> Fee Structure</a>
      <a href="/apply.html"         target="_blank" class="nav-item ext"><i class="fas fa-file-pen"></i> Apply Now</a>
    </div>
  </nav>

  <div class="sidebar-footer">
    <a href="/contact.html" target="_blank" class="sb-footer-link"><i class="fas fa-envelope"></i> Contact School</a>
    <span class="sb-version">Dashboard v1.0</span>
  </div>
</aside>

<!-- ═══ MAIN WRAPPER ═══ -->
<div class="main-wrapper" id="mainWrapper">

  <!-- TOP BAR -->
  <header class="topbar">
    <div class="topbar-left">
      <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
      <div class="breadcrumb">
        <span>SFG Suwerwa</span>
        <i class="fas fa-chevron-right"></i>
        <span id="breadcrumbSection">Dashboard</span>
      </div>
    </div>
    <div class="topbar-right">
      <div class="search-wrap">
        <i class="fas fa-search"></i>
        <input type="text" placeholder="Search pages, staff, news…" id="globalSearch">
        <div class="search-results" id="searchResults"></div>
      </div>
      <button class="tb-btn notif-btn" id="notifBtn" title="Notifications">
        <i class="fas fa-bell"></i>
        <span class="badge">4</span>
      </button>
      <div class="notif-panel" id="notifPanel">
        <div class="notif-header">Notifications <span class="notif-clear" id="notifClear">Clear all</span></div>
        <div class="notif-item unread"><i class="fas fa-user-plus"></i><div><strong>New application</strong><br>Form 1 intake 2025 received<br><small>2 hours ago</small></div></div>
        <div class="notif-item unread"><i class="fas fa-newspaper"></i><div><strong>News post due</strong><br>Inter-school games report pending<br><small>5 hours ago</small></div></div>
        <div class="notif-item unread"><i class="fas fa-money-bill"></i><div><strong>Fee reminder</strong><br>Term 3 fee deadline approaching<br><small>1 day ago</small></div></div>
        <div class="notif-item unread"><i class="fas fa-award"></i><div><strong>KCSE update</strong><br>2024 results officially released<br><small>2 days ago</small></div></div>
      </div>
      <a href="/index.html" target="_blank" class="tb-btn view-site-btn">
        <i class="fas fa-external-link-alt"></i> View Site
      </a>
      <div class="user-menu" id="userMenu">
        <div class="user-avatar"><%= user.username.charAt(0).toUpperCase() %></div>
        <span class="user-name"><%= user.username %></span>
        <form method="POST" action="/admin/logout" class="logout-form">
          <button type="submit" class="logout-btn" title="Log out"><i class="fas fa-sign-out-alt"></i></button>
        </form>
      </div>
    </div>
  </header>

  <%- include(page, { user }) %>

</div><!-- /main-wrapper -->

<!-- SIDEBAR OVERLAY (mobile) -->
<div class="sidebar-overlay" id="sidebarOverlay"></div>

<script src="/admin/static/dashboard.js"></script>
</body>
</html>
