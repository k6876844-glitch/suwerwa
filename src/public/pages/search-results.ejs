<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Search Results  St Francis Girls Suwerwa</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,800;1,600&family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel='stylesheet' href='/high.css'/>


  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/></head>
<body>

<%- include('../layout/header-simple', { navActive: null }) %>


<section class="hero">
  <div class="hero-inner">
    <div class="breadcrumb"><a href="index.html">SFGS</a> <span>/</span> Search</div>
    <h2>Search <em>Results</em></h2>
    <div class="hero-divider"></div>
    <p class="hero-tagline">Search across every page on the SFG Suwerwa website.</p>
  </div>
</section>

<div class="main-wrap">
  <main class="content">

    <form class="search-results-form" action="/search-results.html" method="get">
      <input type="text" name="q" value="<%= query %>" placeholder="Search the website..." aria-label="Search"/>
      <button type="submit"><i class="fas fa-search"></i> Search</button>
    </form>

    <% if (!query) { %>
      <div class="search-empty-state">
        <i class="fas fa-magnifying-glass"></i>
        <p>Enter a search term above to find content anywhere on the site  academics, admissions, fees, staff, results, and more.</p>
      </div>
    <% } else if (results.length === 0) { %>
      <div class="search-empty-state">
        <i class="fas fa-circle-info"></i>
        <p>No results found for <strong>&ldquo;<%= query %>&rdquo;</strong>. Try a different word, or check one of these popular pages:</p>
        <div class="search-suggestions">
          <a href="/adm-overview.html">Admission</a>
          <a href="/fee.html">Fee Payment</a>
          <a href="/kcse.html">KCSE Results</a>
          <a href="/contact.html">Contact Us</a>
        </div>
      </div>
    <% } else { %>
      <p class="search-results-count"><%= results.length %> result<%= results.length === 1 ? '' : 's' %> for &ldquo;<%= query %>&rdquo;</p>
      <div class="search-result-list">
        <% results.forEach(function(result) { %>
        <div class="search-result-item">
          <h3><a href="<%= result.url %>"><%= result.title %></a></h3>
          <span class="search-result-url"><%= result.url %></span>
          <p><%- result.excerptHtml %></p>
        </div>
        <% }); %>
      </div>
    <% } %>

  </main>

  <aside class="sidebar">
    <div class="sidebar-card">
      <div class="sidebar-card-header">
        <h4>Popular Pages</h4>
      </div>
      <div class="sidebar-card-body">
        <a class="sidebar-link" href="profile.html">Our Profile <span class="arrow"></span></a>
        <a class="sidebar-link" href="kcse.html">KCSE Results <span class="arrow"></span></a>
        <a class="sidebar-link" href="fee.html">Fee Payment <span class="arrow"></span></a>
        <a class="sidebar-link" href="apply.html">How to Apply <span class="arrow"></span></a>
        <a class="sidebar-link" href="parentzone.html">Parent Zone <span class="arrow"></span></a>
      </div>
    </div>

    <div class="apply-cta">
      <h4>Applications Open</h4>
      <p>Join one of Kenya's most prestigious schools. Applications for the next intake are now being accepted.</p>
      <a class="apply-btn" href="https://www.sfgsuwerwa.sc.ke/application" target="_blank">How to Apply </a>
    </div>
  </aside>
</div>

<%- include('../layout/footer') %>
<%- include('../layout/sticky-toggle') %>
</body>
</html>
