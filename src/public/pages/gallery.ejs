<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gallery – St Francis Girls Suwerwa</title>
  <link rel="stylesheet" href="/high.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;900&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
</head>
<body>

<%- include('../layout/header-full', { navActive: 'gallery' }) %>

<!-- PAGE HERO BANNER -->
<section class="page-hero">
  <div class="page-hero-overlay"></div>
  <div class="page-hero-content">
    <p class="eyebrow">St Francis Girls Secondary School</p>
    <h1>Our Gallery</h1>
    <nav class="breadcrumb" aria-label="breadcrumb">
      <a href="/index.html">Home</a>
      <span><i class="fas fa-chevron-right"></i></span>
      <span>Gallery</span>
    </nav>
  </div>
</section>

<!-- GALLERY SECTION -->
<section class="gallery-section">
  <div class="gallery-header">
    <p class="section-label">Visual Stories</p>
    <h2>Explore Our School</h2>
    <p class="gallery-subtitle">A glimpse into life at St Francis Girls — academics, sports, culture, and community.</p>
  </div>

  <!-- FILTER TABS -->
  <div class="gallery-filters">
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="academics">Academics</button>
    <button class="filter-btn" data-filter="sports">Sports &amp; Games</button>
    <button class="filter-btn" data-filter="events">Events</button>
    <button class="filter-btn" data-filter="campus">Campus</button>
    <button class="filter-btn" data-filter="scouts">Scouts &amp; Clubs</button>
  </div>

  <!-- GALLERY GRID -->
  <div class="gallery-grid" id="galleryGrid">

    <!-- Academics -->
    <div class="gallery-item" data-category="academics" data-caption="Students engaged in classroom learning">
      <img src="https://images.unsplash.com/photo-1580582932707-520aed937b7b?w=600&q=80" alt="Classroom Learning" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Classroom Learning</span>
      </div>
    </div>

    <div class="gallery-item" data-category="academics" data-caption="Biology laboratory session">
      <img src="https://images.unsplash.com/photo-1532094349884-543559244dee?w=600&q=80" alt="Biology Laboratory" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Biology Laboratory</span>
      </div>
    </div>

    <div class="gallery-item" data-category="academics" data-caption="Library and reading sessions">
      <img src="https://images.unsplash.com/photo-1524178232363-1fb2b075b655?w=600&q=80" alt="Library Session" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Library Session</span>
      </div>
    </div>

    <div class="gallery-item" data-category="academics" data-caption="Computer lab and ICT lessons">
      <img src="https://images.unsplash.com/photo-1588072432836-e10032774350?w=600&q=80" alt="ICT Lab" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>ICT Lab</span>
      </div>
    </div>

    <!-- Sports -->
    <div class="gallery-item" data-category="sports" data-caption="Athletics and field events">
      <img src="https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=600&q=80" alt="Athletics" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Athletics</span>
      </div>
    </div>

    <div class="gallery-item" data-category="sports" data-caption="Netball tournament 2024">
      <img src="https://images.unsplash.com/photo-1546519638405-a9f9c4e4cddb?w=600&q=80" alt="Netball Tournament" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Netball Tournament</span>
      </div>
    </div>

    <div class="gallery-item" data-category="sports" data-caption="Inter-school football competition">
      <img src="https://images.unsplash.com/photo-1459865264687-595d652de67e?w=600&q=80" alt="Football Competition" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Football Competition</span>
      </div>
    </div>

    <div class="gallery-item" data-category="sports" data-caption="Swimming gala event">
      <img src="https://images.unsplash.com/photo-1519315901367-f34ff9154487?w=600&q=80" alt="Swimming Gala" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Swimming Gala</span>
      </div>
    </div>

    <!-- Events -->
    <div class="gallery-item" data-category="events" data-caption="Annual Prize Giving Day ceremony">
      <img src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=600&q=80" alt="Prize Giving Day" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Prize Giving Day</span>
      </div>
    </div>

    <div class="gallery-item" data-category="events" data-caption="School parade and march past">
      <img src="https://images.unsplash.com/photo-1511578314322-379afb476865?w=600&q=80" alt="School Parade" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>School Parade</span>
      </div>
    </div>

    <div class="gallery-item" data-category="events" data-caption="Cultural and music festival">
      <img src="https://images.unsplash.com/photo-1522158637959-30385a09e0da?w=600&q=80" alt="Cultural Festival" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Cultural Festival</span>
      </div>
    </div>

    <div class="gallery-item" data-category="events" data-caption="Graduation and KCSE celebration">
      <img src="https://images.unsplash.com/photo-1523580494863-6f3031224c94?w=600&q=80" alt="Graduation" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Graduation Day</span>
      </div>
    </div>

    <!-- Campus -->
    <div class="gallery-item" data-category="campus" data-caption="Main school building and entrance">
      <img src="https://images.unsplash.com/photo-1562774053-701939374585?w=600&q=80" alt="School Building" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>School Building</span>
      </div>
    </div>

    <div class="gallery-item" data-category="campus" data-caption="School chapel and prayer grounds">
      <img src="https://images.unsplash.com/photo-1519681393784-d120267933ba?w=600&q=80" alt="School Chapel" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>School Chapel</span>
      </div>
    </div>

    <div class="gallery-item" data-category="campus" data-caption="Dormitories and boarding facilities">
      <img src="https://images.unsplash.com/photo-1555854877-bab0e564b8d5?w=600&q=80" alt="Boarding Facilities" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Boarding Facilities</span>
      </div>
    </div>

    <div class="gallery-item" data-category="campus" data-caption="Sports fields and recreation area">
      <img src="https://images.unsplash.com/photo-1529900748604-07564a03e7a6?w=600&q=80" alt="Sports Fields" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Sports Fields</span>
      </div>
    </div>

    <!-- Scouts & Clubs -->
    <div class="gallery-item" data-category="scouts" data-caption="Kenya Girl Guides activities">
      <img src="https://images.unsplash.com/photo-1516321497487-e288fb19713f?w=600&q=80" alt="Girl Guides" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Girl Guides</span>
      </div>
    </div>

    <div class="gallery-item" data-category="scouts" data-caption="Drama club performance">
      <img src="https://images.unsplash.com/photo-1507676184212-d03ab07a01bf?w=600&q=80" alt="Drama Club" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Drama Club</span>
      </div>
    </div>

    <div class="gallery-item" data-category="scouts" data-caption="Debate and public speaking club">
      <img src="https://images.unsplash.com/photo-1475721027785-f74eccf877e2?w=600&q=80" alt="Debate Club" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Debate Club</span>
      </div>
    </div>

    <div class="gallery-item" data-category="scouts" data-caption="Environmental and conservation club">
      <img src="https://images.unsplash.com/photo-1542601906897-d4be9c57ef56?w=600&q=80" alt="Environmental Club" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Environmental Club</span>
      </div>
    </div>

    <div class="gallery-item" data-category="academics" data-caption="Chemistry practical experiment">
      <img src="https://images.unsplash.com/photo-1507413245164-6160d8298b31?w=600&q=80" alt="Chemistry Lab" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Chemistry Lab</span>
      </div>
    </div>

    <div class="gallery-item" data-category="events" data-caption="Sports day opening ceremony">
      <img src="https://images.unsplash.com/photo-1461896836934-ffe607ba8211?w=600&q=80" alt="Sports Day" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Sports Day</span>
      </div>
    </div>

    <div class="gallery-item" data-category="campus" data-caption="School garden and agriculture">
      <img src="https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600&q=80" alt="School Garden" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>School Garden</span>
      </div>
    </div>

    <div class="gallery-item" data-category="sports" data-caption="Basketball practice session">
      <img src="https://images.unsplash.com/photo-1574623452334-1e0ac2b3ccb4?w=600&q=80" alt="Basketball" loading="lazy">
      <div class="gallery-overlay">
        <i class="fas fa-search-plus"></i>
        <span>Basketball</span>
      </div>
    </div>

  </div><!-- /.gallery-grid -->

  <div class="gallery-no-results" id="galleryNoResults" style="display:none;">
    <i class="fas fa-images"></i>
    <p>No photos in this category yet.</p>
  </div>

</section>

<!-- LIGHTBOX MODAL -->
<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
  <button class="lightbox-close" id="lightboxClose" aria-label="Close"><i class="fas fa-times"></i></button>
  <button class="lightbox-prev" id="lightboxPrev" aria-label="Previous"><i class="fas fa-chevron-left"></i></button>
  <button class="lightbox-next" id="lightboxNext" aria-label="Next"><i class="fas fa-chevron-right"></i></button>
  <div class="lightbox-inner">
    <img src="" alt="" id="lightboxImg">
    <p class="lightbox-caption" id="lightboxCaption"></p>
    <span class="lightbox-counter" id="lightboxCounter"></span>
  </div>
</div>

<%- include('../layout/footer') %>
<%- include('../layout/search-overlay') %>
</body>
</html>
