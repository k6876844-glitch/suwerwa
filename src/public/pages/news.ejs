<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>News and Events  St Francis Girls Suwerwa</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,800;1,600&family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel='stylesheet' href='/high.css'/>


  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/></head>
<body>


<%- include('../layout/header-simple', { navActive: 'aboutUs' }) %>


<section class="hero">
  <div class="hero-inner">
    <div class="breadcrumb"><a href="index.html">SFGS</a> <span>/</span> Information <span>/</span> News and Events</div>
    <h2>News <em>&amp; Events</em></h2>
    <div class="hero-divider"></div>
    <p class="hero-tagline">Stories, ceremonies, achievements, and milestones from across the SFGS community.</p>
  </div>
</section>
<div class="motto-strip">
  <span class="star"></span>
  <p>What's Happening at Kabarak</p>
  <span class="star"></span>
</div>
<div class="main-wrap">
  <main class="content">
<p>Stay up to date with the latest news, achievements, and events at St Francis Girls Suwerwa. From annual Prize-Giving ceremonies and KCSE celebrations to international academic competitions and sporting milestones  there's always something inspiring happening at SFGS.</p>

<% if (news.length) { %>
<% var featured = news[0]; var fDate = new Date(featured.created_at); %>
<div class="featured-news">
  <div class="featured-date">
    <div class="day"><%= fDate.toLocaleDateString('en-GB', { day: '2-digit' }) %></div>
    <div class="month"><%= fDate.toLocaleDateString('en-GB', { month: 'short' }) %></div>
  </div>
  <div>
    <span class="featured-label"><%= featured.image_emoji || '📰' %> Featured Story</span>
    <h3><%= featured.title %></h3>
    <p><%= featured.content %></p>
  </div>
</div>
<% } %>

<h2 class="section-heading">Latest News &amp; Events</h2>
<div class="news-grid">
<% if (!news.length) { %>
  <p>No news articles have been published yet.</p>
<% } %>
<% news.forEach(function (n) { var d = new Date(n.created_at); %>
  <div class="news-card">
    <div class="news-thumb"><span class="news-date-mini"><%= d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) %></span><%= n.image_emoji || '📰' %></div>
    <div class="news-body">
      <h4><%= n.title %></h4>
      <p><%= n.content %></p>
      <span class="news-author">By <%= n.author %></span>
    </div>
  </div>
<% }); %>
</div>

<h2 class="section-heading">Upcoming Events</h2>
<div class="events-grid">
<% var upcomingEvents = events.filter(function (ev) { return new Date(ev.event_date) >= new Date(); }); %>
<% if (!upcomingEvents.length) { %>
  <p>No upcoming events at this time.</p>
<% } %>
<% upcomingEvents.forEach(function (ev) {
     var ed = new Date(ev.event_date);
     var evPhotos = photos.filter(function (p) { return p.event_id === ev.id; });
%>
  <div class="event-card">
    <div class="event-card-date">
      <span class="day"><%= ed.toLocaleDateString('en-GB', { day: '2-digit' }) %></span>
      <span class="mon"><%= ed.toLocaleDateString('en-GB', { month: 'short' }) %></span>
    </div>
    <div class="event-card-body">
      <span class="event-card-type"><%= ev.event_type %></span>
      <h4><%= ev.title %></h4>
      <% if (ev.description) { %><p><%= ev.description %></p><% } %>
      <p class="event-card-venue"><i class="fas fa-map-marker-alt"></i> <%= ev.venue %></p>
      <% if (evPhotos.length) { %>
      <div class="event-photo-strip">
        <% evPhotos.forEach(function (p) { %>
          <img src="<%= p.url %>" alt="<%= p.caption %>" loading="lazy">
        <% }); %>
      </div>
      <% } %>
    </div>
  </div>
<% }); %>
</div>
</main>
  <aside class="sidebar">
<div class="sidebar-card">
  <div class="sidebar-card-header"><h4>Information Desk</h4></div>
  <div class="sidebar-card-body"><a class="sidebar-link active" href="news.html">News and Events <span class="arrow"></span></a><a class="sidebar-link" href="noticeboard.html">School Notice Board <span class="arrow"></span></a><a class="sidebar-link" href="games.html">Games &amp; Sports <span class="arrow"></span></a><a class="sidebar-link" href="clubs.html">Clubs &amp; Societies <span class="arrow"></span></a><a class="sidebar-link" href="leadership.html">Student Leadership <span class="arrow"></span></a><a class="sidebar-link" href="facilities.html">Facilities &amp; Amenities <span class="arrow"></span></a></div>
</div>
<div class="apply-cta">
  <h4>Applications Open</h4>
  <p>Join one of Kenya's most prestigious schools. Applications are now being accepted.</p>
  <a class="apply-btn" href="https://www.sfgsuwerwa.sc.ke/application" target="_blank">How to Apply </a>
</div>
</aside>
</div>


<%- include('../layout/footer') %>
<%- include('../layout/sticky-toggle') %>
</body>
</html>
