<li<% if (typeof active !== 'undefined' && active) { %> class="active"<% } %>>
  <a href="#"><%= label %> <i class="fas fa-chevron-down icon-chevron"></i></a>
  <ul class="dropdown">
    <% items.forEach(function(item) { %>
    <li><a href="<%= item.href %>"><%- item.label %></a></li>
    <% }); %>
  </ul>
</li>
